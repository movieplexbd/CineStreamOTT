<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- Default Light / White Theme (Material 3) -->
    <style name="Theme.OTTStreamingApp" parent="Theme.Material3.Light.NoActionBar">
        <item name="colorPrimary">@color/brand_primary</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorPrimaryContainer">@color/red_soft</item>
        <item name="colorOnPrimaryContainer">@color/brand_primary</item>
        <item name="colorSecondary">@color/brand_secondary</item>
        <item name="colorOnSecondary">@color/white</item>
        <item name="colorSecondaryContainer">@color/surface2</item>
        <item name="colorTertiary">@color/blue</item>
        <item name="colorSurface">@color/surface</item>
        <item name="colorOnSurface">@color/t1</item>
        <item name="colorSurfaceVariant">@color/surface2</item>
        <item name="colorOnSurfaceVariant">@color/t2</item>
        <item name="colorOutline">@color/border</item>
        <item name="android:colorBackground">@color/bg</item>
        <item name="android:windowBackground">@color/bg</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@color/white</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:windowActivityTransitions">true</item>
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
    </style>

    <style name="Theme.OTTStreamingApp.NoActionBar" parent="Theme.OTTStreamingApp" />

    <!-- Player Theme (Always dark) -->
    <style name="Theme.OTTStreamingApp.Player" parent="Theme.Material3.Dark.NoActionBar">
        <item name="colorPrimary">@color/brand_primary</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSurface">#141414</item>
        <item name="android:colorBackground">#000000</item>
        <item name="android:windowBackground">#000000</item>
        <item name="android:statusBarColor">#000000</item>
        <item name="android:navigationBarColor">#000000</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
    </style>

    <!-- Legacy Dark alias -->
    <style name="Theme.OTTStreamingApp.Dark" parent="Theme.OTTStreamingApp.Player" />

    <!-- Splash -->
    <style name="Theme.OTTStreamingApp.Splash" parent="Theme.OTTStreamingApp.NoActionBar">
        <item name="android:windowBackground">@color/bg</item>
        <item name="android:statusBarColor">@color/bg</item>
        <item name="android:windowLightStatusBar">true</item>
    </style>

    <!-- Login -->
    <style name="Theme.OTTStreamingApp.Login" parent="Theme.OTTStreamingApp">
        <item name="android:windowSoftInputMode">adjustResize</item>
    </style>

    <!-- Bottom Nav Text Styles -->
    <style name="BottomNavTextActive" parent="TextAppearance.MaterialComponents.Caption">
        <item name="android:textSize">11sp</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>

    <style name="BottomNavTextInactive" parent="TextAppearance.MaterialComponents.Caption">
        <item name="android:textSize">10sp</item>
        <item name="android:fontFamily">sans-serif</item>
    </style>

    <!-- Circular image shape for actor cards -->
    <style name="CircleImageStyle" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">50%</item>
    </style>

</resources>
