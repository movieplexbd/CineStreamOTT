<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg"
    android:scrollbars="none"
    android:overScrollMode="never">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="40dp">

        <!-- Header -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="220dp"
            android:background="@drawable/bg_sub_header">

            <ImageButton
                android:id="@+id/btn_back"
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:layout_gravity="top|start"
                android:layout_margin="16dp"
                android:background="@drawable/bg_close_btn"
                android:src="@drawable/ic_arrow_back"
                android:contentDescription="Back"
                android:padding="8dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="bottom"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🔥 সীমিত অফার"
                    android:textColor="#E8431C"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:background="@drawable/bg_offer_badge"
                    android:paddingHorizontal="10dp"
                    android:paddingVertical="4dp"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="এক্সক্লুসিভ চা প্যাক"
                    android:textColor="#FFFFFF"
                    android:textSize="26sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="4dp" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="৳১০"
                        android:textColor="#FFFFFF"
                        android:textSize="32sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="/এককালীন"
                        android:textColor="#DDDDDD"
                        android:textSize="14sp"
                        android:layout_marginStart="6dp"
                        android:layout_marginBottom="4dp" />

                </LinearLayout>

            </LinearLayout>
        </FrameLayout>

        <!-- Description Card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="16dp"
            app:cardBackgroundColor="@color/surface"
            app:cardCornerRadius="16dp"
            app:cardElevation="2dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="সদ্য মুক্তি পাওয়া নতুন সকল মুভি গুলোর বাংলা ডাবিং পেয়ে যান মাত্র ১০ টাকায় এক মাসের অ্যাক্সেস। মাত্র একটি চায়ের দামে! 🔥"
                    android:textColor="@color/t2"
                    android:textSize="14sp"
                    android:lineSpacingMultiplier="1.6" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Features Card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="12dp"
            app:cardBackgroundColor="@color/surface"
            app:cardCornerRadius="16dp"
            app:cardElevation="2dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="আপনি যা পাবেন"
                    android:textColor="@color/t1"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="14dp" />

                <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:text="✔  সকল নতুন মুভির বাংলা ডাবিং মুভি পাবেন"
                    android:textColor="@color/t2" android:textSize="13sp"
                    android:lineSpacingMultiplier="1.5" android:paddingVertical="5dp" />
                <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:text="✔  এক ক্লিকে ডাউনলোড সুবিধা"
                    android:textColor="@color/t2" android:textSize="13sp"
                    android:lineSpacingMultiplier="1.5" android:paddingVertical="5dp" />
                <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:text="✔  অনলাইন প্লে সাপোর্ট (ডাউনলোড ছাড়াই সরাসরি মুভি দেখুন)"
                    android:textColor="@color/t2" android:textSize="13sp"
                    android:lineSpacingMultiplier="1.5" android:paddingVertical="5dp" />
                <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:text="✔  শর্ট সেকশন থেকে শর্ট ভিডিও দেখে মুভি সিলেক্ট করতে পারবেন"
                    android:textColor="@color/t2" android:textSize="13sp"
                    android:lineSpacingMultiplier="1.5" android:paddingVertical="5dp" />
                <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:text="✔  সকল মুভির বাংলা ডাবিং"
                    android:textColor="@color/t2" android:textSize="13sp"
                    android:lineSpacingMultiplier="1.5" android:paddingVertical="5dp" />
                <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:text="✔  আনলিমিটেড মুভি কালেকশন"
                    android:textColor="@color/t2" android:textSize="13sp"
                    android:lineSpacingMultiplier="1.5" android:paddingVertical="5dp" />
                <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:text="✔  Animal, বাহুবালি, Spiderman, Avengers টাইপ সকল ইন্ডিয়ান, হলিউড ও কোরিয়ান মুভির বাংলা ডাবিং পাবেন"
                    android:textColor="@color/t2" android:textSize="13sp"
                    android:lineSpacingMultiplier="1.5" android:paddingVertical="5dp" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Pricing Options Card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="12dp"
            app:cardBackgroundColor="@color/surface"
            app:cardCornerRadius="16dp"
            app:cardElevation="2dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="প্যাকেজ বেছে নিন"
                    android:textColor="@color/t1"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="14dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gap="12dp">

                    <!-- Monthly Plan -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp"
                        android:background="@drawable/bg_plan_selected"
                        android:gravity="center">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="১ মাস"
                            android:textColor="@color/t1"
                            android:textSize="14sp"
                            android:textStyle="bold" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="৳১০"
                            android:textColor="@color/red"
                            android:textSize="22sp"
                            android:textStyle="bold"
                            android:layout_marginTop="4dp" />
                    </LinearLayout>

                    <!-- Yearly Plan -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp"
                        android:background="@drawable/bg_plan_unselected"
                        android:gravity="center">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="১ বছর (অফার)"
                            android:textColor="@color/t1"
                            android:textSize="14sp"
                            android:textStyle="bold" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="৳৫০"
                            android:textColor="@color/red"
                            android:textSize="22sp"
                            android:textStyle="bold"
                            android:layout_marginTop="4dp" />
                    </LinearLayout>
                </LinearLayout>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="আপনার এন্টারটেইনমেন্ট এর কাছে ১০ টাকা বা ৫০ টাকা খুবই কম যেটা আপনি প্রতিদিন এমনিই খরচ করেন। তাই আজই সাবস্ক্রাইব করুন!"
                    android:textColor="@color/t2"
                    android:textSize="12sp"
                    android:layout_marginTop="16dp"
                    android:fontStyle="italic"
                    android:gravity="center" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Payment Form Card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="12dp"
            app:cardBackgroundColor="@color/surface"
            app:cardCornerRadius="16dp"
            app:cardElevation="2dp">

            <LinearLayout
                android:id="@+id/layout_form"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="পেমেন্ট করুন"
                    android:textColor="@color/t1"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="14dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="@drawable/bg_number_box"
                    android:padding="12dp">

                    <TextView
                        android:id="@+id/tv_payment_number"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:text="01913305107"
                        android:textColor="@color/t1"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                    <Button
                        android:id="@+id/btn_copy"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:text="কপি"
                        android:textSize="12sp"
                        style="@style/Widget.MaterialComponents.Button.TextButton"
                        android:textColor="@color/red" />
                </LinearLayout>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="উপরের নম্বরে বিকাশ (bKash) সেন্ড মানি করুন"
                    android:textColor="@color/t3"
                    android:textSize="11sp"
                    android:layout_marginTop="6dp"
                    android:layout_marginBottom="16dp" />

                <EditText
                    android:id="@+id/et_transaction_id"
                    android:layout_width="match_parent"
                    android:layout_height="54dp"
                    android:hint="ট্রানজেকশন আইডি (TrxID)"
                    android:inputType="textCapCharacters"
                    android:background="@drawable/bg_input_field"
                    android:paddingHorizontal="16dp"
                    android:textSize="15sp" />

                <Button
                    android:id="@+id/btn_submit"
                    android:layout_width="match_parent"
                    android:layout_height="54dp"
                    android:layout_marginTop="20dp"
                    android:text="সাবমিট করুন"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    app:cornerRadius="12dp"
                    android:backgroundTint="@color/red" />

                <ProgressBar
                    android:id="@+id/progress_bar"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:layout_gravity="center"
                    android:layout_marginTop="16dp"
                    android:visibility="gone" />

            </LinearLayout>

            <LinearLayout
                android:id="@+id/layout_success"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="40dp"
                android:visibility="gone">

                <ImageView
                    android:layout_width="80dp"
                    android:layout_height="80dp"
                    android:src="@drawable/ic_check_circle"
                    app:tint="@color/green" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="সাবমিট সফল হয়েছে!"
                    android:textColor="@color/t1"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:layout_marginTop="20dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="আপনার পেমেন্ট রিভিউ করা হচ্ছে। কিছুক্ষণের মধ্যেই প্রিমিয়াম অ্যাক্সেস পেয়ে যাবেন।"
                    android:textColor="@color/t2"
                    android:textSize="14sp"
                    android:gravity="center"
                    android:layout_marginTop="10dp" />

                <Button
                    android:id="@+id/btn_done"
                    android:layout_width="match_parent"
                    android:layout_height="54dp"
                    android:layout_marginTop="30dp"
                    android:text="ঠিক আছে"
                    app:cornerRadius="12dp"
                    android:backgroundTint="@color/red" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
