<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/black">

    <!-- Video surface -->
    <androidx.media3.ui.PlayerView
        android:id="@+id/player_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:use_controller="false"
        app:surface_type="surface_view"
        app:resize_mode="fit"
        android:background="@color/black" />

    <!-- Loading / Buffering overlay -->
    <FrameLayout
        android:id="@+id/loading_overlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#55000000"
        android:visibility="visible">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:orientation="vertical"
            android:gravity="center">

            <ProgressBar
                android:id="@+id/progress_buffering"
                android:layout_width="60dp"
                android:layout_height="60dp"
                android:layout_gravity="center"
                android:indeterminateTint="@color/red" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="লোড হচ্ছে..."
                android:textColor="@color/white"
                android:textSize="13sp"
                android:layout_marginTop="12dp" />
        </LinearLayout>
    </FrameLayout>

    <!-- Transparent gesture capture area (above player, below controls) -->
    <View
        android:id="@+id/gesture_area"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/transparent"
        android:clickable="true"
        android:focusable="true" />

    <!-- Seek forward indicator (double-tap right) -->
    <LinearLayout
        android:id="@+id/seek_forward_indicator"
        android:layout_width="100dp"
        android:layout_height="100dp"
        android:layout_gravity="center_vertical|end"
        android:layout_marginEnd="60dp"
        android:orientation="vertical"
        android:gravity="center"
        android:background="@drawable/bg_seek_indicator"
        android:visibility="gone"
        android:alpha="0">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="▶▶"
            android:textColor="@color/white"
            android:textSize="20sp" />
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="+10s"
            android:textColor="@color/white"
            android:textSize="11sp"
            android:layout_marginTop="4dp" />
    </LinearLayout>

    <!-- Seek back indicator (double-tap left) -->
    <LinearLayout
        android:id="@+id/seek_back_indicator"
        android:layout_width="100dp"
        android:layout_height="100dp"
        android:layout_gravity="center_vertical|start"
        android:layout_marginStart="60dp"
        android:orientation="vertical"
        android:gravity="center"
        android:background="@drawable/bg_seek_indicator"
        android:visibility="gone"
        android:alpha="0">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="◀◀"
            android:textColor="@color/white"
            android:textSize="20sp" />
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="-10s"
            android:textColor="@color/white"
            android:textSize="11sp"
            android:layout_marginTop="4dp" />
    </LinearLayout>

    <!-- Swipe seek time indicator -->
    <TextView
        android:id="@+id/tv_seek_indicator"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:paddingHorizontal="20dp"
        android:paddingVertical="10dp"
        android:background="@drawable/bg_speed_btn"
        android:textColor="@color/white"
        android:textSize="16sp"
        android:textStyle="bold"
        android:visibility="gone" />

    <!-- Controls overlay -->
    <LinearLayout
        android:id="@+id/controls_overlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:background="@color/player_overlay"
        android:clickable="false"
        android:focusable="false">

        <!-- TOP BAR: Back + Title + Speed + PiP -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="14dp"
            android:background="@drawable/gradient_top">

            <ImageButton
                android:id="@+id/btn_back"
                android:layout_width="38dp"
                android:layout_height="38dp"
                android:src="@drawable/ic_arrow_back"
                android:background="@drawable/bg_icon_btn"
                android:contentDescription="Back" />

            <TextView
                android:id="@+id/tv_player_title"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginHorizontal="12dp"
                android:textColor="@color/white"
                android:textSize="14sp"
                android:textStyle="bold"
                android:singleLine="true"
                android:ellipsize="end" />

            <TextView
                android:id="@+id/tv_speed"
                android:layout_width="wrap_content"
                android:layout_height="34dp"
                android:paddingHorizontal="10dp"
                android:gravity="center"
                android:background="@drawable/bg_speed_btn"
                android:textColor="@color/white"
                android:textSize="11sp"
                android:textStyle="bold"
                android:text="1.0x"
                android:layout_marginEnd="8dp" />

            <ImageButton
                android:id="@+id/btn_pip"
                android:layout_width="34dp"
                android:layout_height="34dp"
                android:src="@drawable/ic_pip"
                android:background="@drawable/bg_icon_btn"
                android:contentDescription="PiP"
                android:padding="6dp" />
        </LinearLayout>

        <!-- MIDDLE: flex spacer -->
        <View android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1" />

        <!-- CENTER CONTROLS: seek back, play/pause, seek forward -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="horizontal"
            android:layout_marginBottom="8dp">

            <ImageButton
                android:id="@+id/btn_seek_back"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:src="@drawable/ic_replay_10"
                android:background="@color/transparent"
                android:contentDescription="Seek back 10s" />

            <ImageButton
                android:id="@+id/btn_play_pause"
                android:layout_width="68dp"
                android:layout_height="68dp"
                android:layout_marginHorizontal="28dp"
                android:src="@drawable/ic_pause"
                android:background="@drawable/bg_play_circle"
                android:contentDescription="Play/Pause" />

            <ImageButton
                android:id="@+id/btn_seek_forward"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:src="@drawable/ic_forward_10"
                android:background="@color/transparent"
                android:contentDescription="Seek forward 10s" />
        </LinearLayout>

        <!-- BOTTOM: seekbar + time -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="14dp"
            android:paddingBottom="16dp"
            android:background="@drawable/gradient_bottom">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/tv_position"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/white"
                    android:textSize="12sp"
                    android:text="00:00" />

                <SeekBar
                    android:id="@+id/seek_bar"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginHorizontal="10dp"
                    android:progressTint="@color/red"
                    android:thumbTint="@color/red"
                    android:max="1000" />

                <TextView
                    android:id="@+id/tv_duration"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/white"
                    android:textSize="12sp"
                    android:text="00:00" />
            </LinearLayout>
        </LinearLayout>

    </LinearLayout>

</FrameLayout>
