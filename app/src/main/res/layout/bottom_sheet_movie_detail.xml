<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@color/surface">

    <!-- Handle bar -->
    <View
        android:layout_width="36dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="10dp"
        android:background="@drawable/bg_handle"
        android:layout_marginBottom="4dp" />

    <!-- Progress while loading -->
    <ProgressBar
        android:id="@+id/progress_detail"
        android:layout_width="38dp"
        android:layout_height="38dp"
        android:layout_gravity="center"
        android:indeterminateTint="@color/red"
        android:layout_margin="24dp"
        android:visibility="gone" />

    <!-- Banner Hero Image -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="220dp"
        android:layout_marginHorizontal="13dp"
        android:layout_marginTop="8dp">

        <ImageView
            android:id="@+id/iv_banner"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop"
            android:background="@color/surface2" />

        <!-- Gradient overlay -->
        <View
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/gradient_bottom_detail" />

        <!-- Close button -->
        <ImageButton
            android:id="@+id/btn_close"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_gravity="top|end"
            android:layout_margin="10dp"
            android:src="@drawable/ic_close"
            android:background="@drawable/bg_close_btn"
            android:contentDescription="Close" />

        <!-- Free badge -->
        <TextView
            android:id="@+id/tv_free_badge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="top|start"
            android:layout_margin="10dp"
            android:text="@string/free_badge"
            android:textSize="10sp"
            android:textStyle="bold"
            android:textColor="@color/white"
            android:paddingLeft="10dp" android:paddingRight="10dp"
            android:paddingTop="4dp" android:paddingBottom="4dp"
            android:background="@drawable/bg_badge_free"
            android:visibility="gone" />

    </FrameLayout>

    <!-- Details body -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:scrollbars="none"
        android:overScrollMode="never">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="13dp">

            <!-- Title -->
            <TextView
                android:id="@+id/tv_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="@color/t1"
                android:fontFamily="serif"
                android:layout_marginTop="6dp" />

            <!-- Meta row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="8dp">

                <TextView
                    android:id="@+id/tv_rating"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="13sp"
                    android:textColor="@color/amber"
                    android:textStyle="bold" />

                <View
                    android:layout_width="4dp"
                    android:layout_height="4dp"
                    android:background="@drawable/dot_mid"
                    android:layout_marginHorizontal="8dp" />

                <TextView
                    android:id="@+id/tv_category"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="12sp"
                    android:textColor="@color/t2"
                    android:background="@drawable/bg_tag"
                    android:paddingLeft="8dp" android:paddingRight="8dp"
                    android:paddingTop="3dp" android:paddingBottom="3dp" />

                <View
                    android:layout_width="4dp"
                    android:layout_height="4dp"
                    android:background="@drawable/dot_mid"
                    android:layout_marginHorizontal="8dp" />

                <TextView
                    android:id="@+id/tv_year"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="12sp"
                    android:textColor="@color/t2" />

            </LinearLayout>

            <!-- Description -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="বিবরণ"
                android:textSize="10sp"
                android:textStyle="bold"
                android:textColor="@color/t3"
                android:letterSpacing="0.08"
                android:layout_marginTop="14dp"
                android:layout_marginBottom="5dp" />

            <TextView
                android:id="@+id/tv_description"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="13sp"
                android:textColor="@color/t2"
                android:lineSpacingMultiplier="1.7" />

            <!-- Action buttons -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="16dp">

                <!-- Watch button -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_play"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="52dp"
                    android:text="▶  দেখুন"
                    android:textSize="14sp"
                    android:textColor="@color/white"
                    android:textStyle="bold"
                    app:backgroundTint="@color/red"
                    app:cornerRadius="13dp"
                    android:layout_marginEnd="8dp" />

                <!-- Download button -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_download"
                    android:layout_width="52dp"
                    android:layout_height="52dp"
                    android:text=""
                    app:icon="@drawable/ic_download"
                    app:iconSize="22dp"
                    app:iconTint="@color/t1"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    app:strokeColor="@color/border"
                    app:strokeWidth="1.5dp"
                    app:cornerRadius="13dp"
                    android:backgroundTint="@color/surface2" />

            </LinearLayout>

            <!-- Subscription lock overlay -->
            <LinearLayout
                android:id="@+id/layout_locked"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:background="@drawable/bg_locked_panel"
                android:padding="18dp"
                android:layout_marginTop="12dp"
                android:alpha="0"
                android:visibility="visible">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🔒"
                    android:textSize="36sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/locked_title"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="@color/t1"
                    android:fontFamily="serif"
                    android:layout_marginTop="10dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/locked_sub"
                    android:textSize="12sp"
                    android:textColor="@color/t2"
                    android:gravity="center"
                    android:layout_marginTop="6dp"
                    android:lineSpacingMultiplier="1.5" />

            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="16dp" />

        </LinearLayout>
    </ScrollView>
</LinearLayout>
