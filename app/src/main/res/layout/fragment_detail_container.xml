<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg">

    <!-- Scrollable content -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scrollbars="none"
        android:overScrollMode="never">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Hero banner -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="260dp">

                <ImageView
                    android:id="@+id/iv_banner"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerCrop"
                    android:background="@color/surface2" />

                <!-- Gradient overlay bottom -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/gradient_bottom_detail" />

                <!-- Back button top-left -->
                <ImageButton
                    android:id="@+id/btn_back"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_gravity="top|start"
                    android:layout_margin="12dp"
                    android:src="@drawable/ic_arrow_back"
                    android:background="@drawable/bg_close_btn"
                    android:contentDescription="Back"
                    android:padding="8dp" />

                <!-- FREE badge top-right -->
                <TextView
                    android:id="@+id/tv_free_badge"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="top|end"
                    android:layout_margin="12dp"
                    android:text="@string/free_badge"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:textColor="@color/white"
                    android:paddingHorizontal="10dp"
                    android:paddingVertical="4dp"
                    android:background="@drawable/bg_badge_free"
                    android:visibility="gone" />

                <!-- Title overlay bottom of banner -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_gravity="bottom"
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:paddingBottom="10dp">

                    <TextView
                        android:id="@+id/tv_title_overlay"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textSize="22sp"
                        android:textStyle="bold"
                        android:textColor="@color/white"
                        android:fontFamily="serif"
                        android:maxLines="2"
                        android:ellipsize="end"
                        android:shadowColor="#88000000"
                        android:shadowDx="0"
                        android:shadowDy="2"
                        android:shadowRadius="6" />

                </LinearLayout>

            </FrameLayout>

            <!-- Loading progress -->
            <ProgressBar
                android:id="@+id/progress_detail"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_gravity="center_horizontal"
                android:indeterminateTint="@color/red"
                android:layout_marginVertical="32dp"
                android:layout_marginStart="auto"
                android:visibility="gone" />

            <!-- Content body -->
            <LinearLayout
                android:id="@+id/layout_content"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp"
                android:visibility="gone">

                <!-- Title (duplicated for scroll visibility) -->
                <TextView
                    android:id="@+id/tv_title"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="@color/t1"
                    android:fontFamily="serif"
                    android:visibility="gone" />

                <!-- Meta chips row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginTop="10dp">

                    <TextView
                        android:id="@+id/tv_rating"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="12sp"
                        android:textColor="@color/amber"
                        android:textStyle="bold"
                        android:background="@drawable/bg_tag"
                        android:paddingHorizontal="10dp"
                        android:paddingVertical="4dp" />

                    <TextView
                        android:id="@+id/tv_year"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="11sp"
                        android:textColor="@color/t2"
                        android:background="@drawable/bg_tag"
                        android:paddingHorizontal="10dp"
                        android:paddingVertical="4dp"
                        android:layout_marginStart="8dp"
                        android:visibility="gone" />

                    <TextView
                        android:id="@+id/tv_duration"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="11sp"
                        android:textColor="@color/t2"
                        android:background="@drawable/bg_tag"
                        android:paddingHorizontal="10dp"
                        android:paddingVertical="4dp"
                        android:layout_marginStart="8dp"
                        android:visibility="gone" />

                </LinearLayout>

                <!-- Category -->
                <TextView
                    android:id="@+id/tv_category"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="11sp"
                    android:textColor="@color/t3"
                    android:layout_marginTop="8dp" />

                <!-- Description -->
                <TextView
                    android:id="@+id/tv_description"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="13sp"
                    android:textColor="@color/t2"
                    android:lineSpacingMultiplier="1.5"
                    android:layout_marginTop="12dp" />

                <!-- Divider -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/surface2"
                    android:layout_marginVertical="16dp" />

                <!-- Action buttons -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center"
                    android:weightSum="2">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_play"
                        android:layout_width="0dp"
                        android:layout_height="48dp"
                        android:layout_weight="1"
                        android:text="▶  দেখুন"
                        android:textSize="14sp"
                        android:textColor="@color/white"
                        android:textStyle="bold"
                        app:backgroundTint="@color/red"
                        app:cornerRadius="10dp"
                        android:layout_marginEnd="6dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_download"
                        android:layout_width="0dp"
                        android:layout_height="48dp"
                        android:layout_weight="1"
                        android:text="↓  ডাউনলোড"
                        android:textSize="14sp"
                        android:textColor="@color/t1"
                        android:textStyle="bold"
                        app:backgroundTint="@color/surface2"
                        app:cornerRadius="10dp"
                        android:layout_marginStart="6dp"
                        app:strokeColor="@color/border"
                        app:strokeWidth="1dp" />

                </LinearLayout>

                <!-- Subscription lock panel -->
                <LinearLayout
                    android:id="@+id/layout_locked"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@drawable/bg_locked_panel"
                    android:padding="24dp"
                    android:layout_marginTop="16dp"
                    android:visibility="gone">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🔒"
                        android:textSize="40sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/locked_title"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="@color/t1"
                        android:fontFamily="serif"
                        android:layout_marginTop="12dp"
                        android:gravity="center" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/locked_sub"
                        android:textSize="13sp"
                        android:textColor="@color/t2"
                        android:gravity="center"
                        android:layout_marginTop="8dp"
                        android:lineSpacingMultiplier="1.5" />

                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="32dp" />

            </LinearLayout>

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

    <!-- Center progress (absolute positioned) -->
    <ProgressBar
        android:id="@+id/progress_center"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:indeterminateTint="@color/red"
        android:visibility="gone"
        android:layout_gravity="center" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>
