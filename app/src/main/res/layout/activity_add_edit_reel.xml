<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg"
    android:orientation="vertical">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/surface">

        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            app:title="রিল যোগ/এডিট"
            app:titleTextColor="@color/t1" />
    </com.google.android.material.appbar.AppBarLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="4dp"
                android:text="রিল শিরোনাম *"
                android:textColor="@color/t2"
                android:textSize="13sp" />

            <EditText
                android:id="@+id/et_reel_title"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginBottom="12dp"
                android:background="@color/surface"
                android:hint="রিল এর নাম লিখুন"
                android:inputType="textCapWords"
                android:padding="12dp"
                android:textColor="@color/t1"
                android:textColorHint="@color/t3"
                android:textSize="14sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="4dp"
                android:text="ভিডিও URL (Direct mp4 বা YouTube) *"
                android:textColor="@color/t2"
                android:textSize="13sp" />

            <EditText
                android:id="@+id/et_reel_video_url"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginBottom="12dp"
                android:background="@color/surface"
                android:hint="https://..."
                android:inputType="textUri"
                android:padding="12dp"
                android:textColor="@color/t1"
                android:textColorHint="@color/t3"
                android:textSize="13sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="4dp"
                android:text="মুভির নাম (সার্চ করার জন্য)"
                android:textColor="@color/t2"
                android:textSize="13sp" />

            <EditText
                android:id="@+id/et_reel_movie_title"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginBottom="12dp"
                android:background="@color/surface"
                android:hint="মুভির নাম লিখুন"
                android:inputType="textCapWords"
                android:padding="12dp"
                android:textColor="@color/t1"
                android:textColorHint="@color/t3"
                android:textSize="14sp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_save_reel"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="24dp"
                android:backgroundTint="@color/red"
                android:text="সংরক্ষণ করুন"
                android:textColor="@color/white"
                android:textSize="16sp"
                app:cornerRadius="13dp" />

        </LinearLayout>
    </ScrollView>
</LinearLayout>
