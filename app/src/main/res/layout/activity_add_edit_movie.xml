<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/surface"
        app:elevation="2dp">
        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="@color/surface"
            app:titleTextColor="@color/t1" />
    </com.google.android.material.appbar.AppBarLayout>

    <ProgressBar
        android:id="@+id/progress_bar"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:layout_gravity="center_horizontal"
        android:indeterminateTint="@color/red"
        android:visibility="gone" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:scrollbars="none"
        android:overScrollMode="never">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="14dp">

            <!-- Title -->
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="মুভির শিরোনাম *" android:textSize="13sp"
                android:textColor="@color/t2" android:layout_marginBottom="4dp"/>
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:layout_marginBottom="12dp">
                <EditText android:id="@+id/et_title"
                    android:layout_width="0dp" android:layout_height="50dp"
                    android:layout_weight="1"
                    android:background="@color/surface" android:padding="12dp"
                    android:textColor="@color/t1" android:textSize="14sp"
                    android:hint="মুভির নাম লিখুন" android:textColorHint="@color/t3"
                    android:inputType="textCapWords"/>
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_fetch_metadata"
                    android:layout_width="wrap_content" android:layout_height="50dp"
                    android:layout_marginStart="8dp"
                    android:text="Fetch"
                    android:textSize="12sp"
                    app:cornerRadius="4dp"
                    android:backgroundTint="@color/red"/>
            </LinearLayout>

            <!-- Description -->
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="বিবরণ" android:textSize="13sp"
                android:textColor="@color/t2" android:layout_marginBottom="4dp"/>
            <EditText android:id="@+id/et_description"
                android:layout_width="match_parent" android:layout_height="100dp"
                android:background="@color/surface" android:padding="12dp"
                android:textColor="@color/t1" android:textSize="14sp"
                android:hint="মুভির বিবরণ লিখুন" android:textColorHint="@color/t3"
                android:inputType="textMultiLine" android:gravity="top"
                android:layout_marginBottom="12dp"/>

            <!-- Banner Image URL -->
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="ব্যানার ছবির URL (মুভি কার্ডের জন্য)" android:textSize="13sp"
                android:textColor="@color/t2" android:layout_marginBottom="4dp"/>
            <EditText android:id="@+id/et_banner_url"
                android:layout_width="match_parent" android:layout_height="50dp"
                android:background="@color/surface" android:padding="12dp"
                android:textColor="@color/t1" android:textSize="13sp"
                android:hint="https://..." android:textColorHint="@color/t3"
                android:inputType="textUri" android:layout_marginBottom="12dp"/>

            <!-- Detail Thumbnail URL -->
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="ডিটেইল থাম্বনেইল URL (16:9 রেশিও)" android:textSize="13sp"
                android:textColor="@color/t2" android:layout_marginBottom="4dp"/>
            <EditText android:id="@+id/et_detail_thumbnail_url"
                android:layout_width="match_parent" android:layout_height="50dp"
                android:background="@color/surface" android:padding="12dp"
                android:textColor="@color/t1" android:textSize="13sp"
                android:hint="https://..." android:textColorHint="@color/t3"
                android:inputType="textUri" android:layout_marginBottom="12dp"/>

            <!-- Video Stream URL -->
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="ভিডিও স্ট্রিম URL *" android:textSize="13sp"
                android:textColor="@color/t2" android:layout_marginBottom="4dp"/>
            <EditText android:id="@+id/et_video_url"
                android:layout_width="match_parent" android:layout_height="50dp"
                android:background="@color/surface" android:padding="12dp"
                android:textColor="@color/t1" android:textSize="13sp"
                android:hint="https://... (.m3u8 বা .mp4)" android:textColorHint="@color/t3"
                android:inputType="textUri" android:layout_marginBottom="12dp"/>

            <!-- Download Qualities Section -->
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="ডাউনলোড কোয়ালিটি (URL এবং সাইজ)" android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="@color/red" android:layout_marginBottom="8dp"/>

            <!-- 360p -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:background="@color/surface" android:padding="8dp"
                android:layout_marginBottom="8dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="360p Quality" android:textColor="@color/t2" android:textSize="12sp"/>
                <EditText android:id="@+id/et_url_360" android:layout_width="match_parent" android:layout_height="45dp"
                    android:hint="URL" android:textSize="13sp" android:textColor="@color/t1" android:background="@android:color/transparent"/>
                <EditText android:id="@+id/et_size_360" android:layout_width="match_parent" android:layout_height="45dp"
                    android:hint="Size (e.g. 300MB)" android:textSize="13sp" android:textColor="@color/t1" android:background="@android:color/transparent"/>
            </LinearLayout>

            <!-- 480p -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:background="@color/surface" android:padding="8dp"
                android:layout_marginBottom="8dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="480p Quality" android:textColor="@color/t2" android:textSize="12sp"/>
                <EditText android:id="@+id/et_url_480" android:layout_width="match_parent" android:layout_height="45dp"
                    android:hint="URL" android:textSize="13sp" android:textColor="@color/t1" android:background="@android:color/transparent"/>
                <EditText android:id="@+id/et_size_480" android:layout_width="match_parent" android:layout_height="45dp"
                    android:hint="Size (e.g. 500MB)" android:textSize="13sp" android:textColor="@color/t1" android:background="@android:color/transparent"/>
            </LinearLayout>

            <!-- 1080p -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:background="@color/surface" android:padding="8dp"
                android:layout_marginBottom="12dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="1080p Quality" android:textColor="@color/t2" android:textSize="12sp"/>
                <EditText android:id="@+id/et_url_1080" android:layout_width="match_parent" android:layout_height="45dp"
                    android:hint="URL" android:textSize="13sp" android:textColor="@color/t1" android:background="@android:color/transparent"/>
                <EditText android:id="@+id/et_size_1080" android:layout_width="match_parent" android:layout_height="45dp"
                    android:hint="Size (e.g. 1.2GB)" android:textSize="13sp" android:textColor="@color/t1" android:background="@android:color/transparent"/>
            </LinearLayout>

            <!-- Category -->
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="ক্যাটাগরি" android:textSize="13sp"
                android:textColor="@color/t2" android:layout_marginBottom="4dp"/>
            <Spinner android:id="@+id/spinner_category"
                android:layout_width="match_parent" android:layout_height="50dp"
                android:background="@color/surface"
                android:padding="12dp"
                android:layout_marginBottom="12dp"/>

            <!-- Year and Duration -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:layout_marginBottom="12dp">
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical"
                    android:layout_marginEnd="6dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="মুক্তির বছর" android:textSize="13sp"
                        android:textColor="@color/t2" android:layout_marginBottom="4dp"/>
                    <EditText android:id="@+id/et_year"
                        android:layout_width="match_parent" android:layout_height="50dp"
                        android:background="@color/surface" android:padding="12dp"
                        android:textColor="@color/t1" android:textSize="14sp"
                        android:hint="যেমন: 2024" android:textColorHint="@color/t3"
                        android:inputType="number"/>
                </LinearLayout>
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical"
                    android:layout_marginStart="6dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="সময়কাল" android:textSize="13sp"
                        android:textColor="@color/t2" android:layout_marginBottom="4dp"/>
                    <EditText android:id="@+id/et_duration"
                        android:layout_width="match_parent" android:layout_height="50dp"
                        android:background="@color/surface" android:padding="12dp"
                        android:textColor="@color/t1" android:textSize="14sp"
                        android:hint="যেমন: 2h 15m" android:textColorHint="@color/t3"
                        android:inputType="text"/>
                </LinearLayout>
            </LinearLayout>

            <!-- IMDB Rating -->
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="IMDb রেটিং (0-10)" android:textSize="13sp"
                android:textColor="@color/t2" android:layout_marginBottom="4dp"/>
            <EditText android:id="@+id/et_rating"
                android:layout_width="match_parent" android:layout_height="50dp"
                android:background="@color/surface" android:padding="12dp"
                android:textColor="@color/t1" android:textSize="14sp"
                android:hint="যেমন: 7.5" android:textColorHint="@color/t3"
                android:inputType="numberDecimal" android:layout_marginBottom="16dp"/>

            <!-- Actors Selection -->
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="অভিনেতা নির্বাচন করুন" android:textSize="13sp"
                android:textColor="@color/t2" android:layout_marginBottom="4dp"/>
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_select_actors"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:text="অভিনেতা সিলেক্ট করুন"
                android:textColor="@color/t1"
                app:strokeColor="@color/surface"
                android:layout_marginBottom="4dp"
                android:gravity="start|center_vertical"
                android:paddingStart="12dp"
                app:icon="@android:drawable/ic_input_add"
                app:iconTint="@color/t2" />
            <TextView
                android:id="@+id/tv_selected_actors"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="কোনো অভিনেতা সিলেক্ট করা নেই"
                android:textSize="12sp"
                android:textColor="@color/t3"
                android:layout_marginBottom="16dp"
                android:paddingHorizontal="4dp"/>

            <!-- Switches -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:gravity="center_vertical"
                android:background="@color/surface" android:padding="14dp"
                android:layout_marginBottom="10dp">
                <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="ট্রেন্ডিং" android:textSize="14sp" android:textColor="@color/t1"/>
                <androidx.appcompat.widget.SwitchCompat
                    android:id="@+id/switch_trending"
                    android:layout_width="wrap_content" android:layout_height="wrap_content" />
            </LinearLayout>

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:gravity="center_vertical"
                android:background="@color/surface" android:padding="14dp"
                android:layout_marginBottom="20dp">
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="ফ্রি মুভি" android:textSize="14sp" android:textColor="@color/t1"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="চালু থাকলে সবাই দেখতে পাবে" android:textSize="11sp"
                        android:textColor="@color/t3"/>
                </LinearLayout>
                <androidx.appcompat.widget.SwitchCompat
                    android:id="@+id/switch_free"
                    android:layout_width="wrap_content" android:layout_height="wrap_content" />
            </LinearLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_save"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="সংরক্ষণ করুন"
                android:textSize="16sp"
                android:textColor="@color/white"
                android:backgroundTint="@color/red"
                app:cornerRadius="13dp" />
        </LinearLayout>
    </ScrollView>
</LinearLayout>
