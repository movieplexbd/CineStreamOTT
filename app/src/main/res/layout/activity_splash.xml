<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg">

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:orientation="vertical"
        android:gravity="center">

        <!-- App Logo with fade-in animation -->
        <ImageView
            android:id="@+id/iv_splash_logo"
            android:layout_width="140dp"
            android:layout_height="140dp"
            android:src="@drawable/app_logo_new"
            android:scaleType="fitCenter"
            android:contentDescription="CineStream Logo" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/app_name"
            android:textColor="@color/brand_primary"
            android:textSize="32sp"
            android:textStyle="bold"
            android:fontFamily="serif"
            android:layout_marginTop="16dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="মুভি স্ট্রিমিং"
            android:textColor="@color/brand_secondary"
            android:textSize="14sp"
            android:textStyle="bold"
            android:layout_marginTop="4dp" />

        <!-- Lottie loading animation -->
        <com.airbnb.lottie.LottieAnimationView
            android:id="@+id/lottie_loading"
            android:layout_width="72dp"
            android:layout_height="72dp"
            android:layout_marginTop="36dp"
            app:lottie_rawRes="@raw/lottie_loading"
            app:lottie_autoPlay="true"
            app:lottie_loop="true" />

    </LinearLayout>

</FrameLayout>
