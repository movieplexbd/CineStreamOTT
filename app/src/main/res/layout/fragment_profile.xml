<?xml version="1.0" encoding="utf-8"?>
  <ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
      xmlns:app="http://schemas.android.com/apk/res-auto"
      android:layout_width="match_parent"
      android:layout_height="match_parent"
      android:background="@color/bg"
      android:scrollbars="none"
      android:overScrollMode="never">

      <LinearLayout
          android:layout_width="match_parent"
          android:layout_height="wrap_content"
          android:orientation="vertical"
          android:paddingBottom="24dp">

          <!-- ══ Hero Profile Card ══ -->
          <com.google.android.material.card.MaterialCardView
              android:layout_width="match_parent"
              android:layout_height="wrap_content"
              android:layout_margin="14dp"
              app:cardElevation="4dp"
              app:cardCornerRadius="20dp"
              app:cardBackgroundColor="@color/surface">

              <LinearLayout
                  android:layout_width="match_parent"
                  android:layout_height="wrap_content"
                  android:orientation="vertical"
                  android:gravity="center"
                  android:padding="28dp">

                  <!-- Avatar with ring -->
                  <FrameLayout
                      android:layout_width="wrap_content"
                      android:layout_height="wrap_content">

                      <de.hdodenhof.circleimageview.CircleImageView
                          android:id="@+id/iv_avatar"
                          android:layout_width="88dp"
                          android:layout_height="88dp"
                          android:src="@color/red"
                          app:civ_border_width="3dp"
                          app:civ_border_color="@color/red"
                          android:contentDescription="Profile photo" />

                  </FrameLayout>

                  <TextView
                      android:id="@+id/tv_name"
                      android:layout_width="wrap_content"
                      android:layout_height="wrap_content"
                      android:text="ব্যবহারকারী"
                      android:textSize="20sp"
                      android:textStyle="bold"
                      android:textColor="@color/t1"
                      android:layout_marginTop="14dp" />

                  <TextView
                      android:id="@+id/tv_email"
                      android:layout_width="wrap_content"
                      android:layout_height="wrap_content"
                      android:textSize="13sp"
                      android:textColor="@color/t2"
                      android:layout_marginTop="4dp" />

                  <!-- Subscription badge -->
                  <TextView
                      android:id="@+id/tv_plan_label"
                      android:layout_width="wrap_content"
                      android:layout_height="32dp"
                      android:paddingHorizontal="18dp"
                      android:gravity="center"
                      android:textSize="12sp"
                      android:textStyle="bold"
                      android:textColor="@color/white"
                      android:background="@drawable/bg_free_badge"
                      android:layout_marginTop="12dp"
                      android:text="ফ্রি প্ল্যান" />

                  <TextView
                      android:id="@+id/tv_expiry"
                      android:layout_width="wrap_content"
                      android:layout_height="wrap_content"
                      android:textSize="12sp"
                      android:textColor="@color/t3"
                      android:layout_marginTop="6dp"
                      android:visibility="gone" />

                  <!-- Subscribe CTA button -->
                  <com.google.android.material.button.MaterialButton
                      android:id="@+id/btn_subscribe"
                      android:layout_width="match_parent"
                      android:layout_height="48dp"
                      android:layout_marginTop="20dp"
                      android:text="প্রিমিয়াম আপগ্রেড করুন ✨"
                      android:textSize="14sp"
                      android:textStyle="bold"
                      android:textColor="@color/white"
                      app:cornerRadius="24dp"
                      app:backgroundTint="@color/red"
                      app:icon="@null"
                      android:contentDescription="Subscribe to premium" />

              </LinearLayout>
          </com.google.android.material.card.MaterialCardView>

          <!-- ══ Admin Control Card (hidden for non-admins) ══ -->
          <com.google.android.material.card.MaterialCardView
              android:id="@+id/btn_admin"
              android:layout_width="match_parent"
              android:layout_height="wrap_content"
              android:layout_marginHorizontal="14dp"
              android:layout_marginBottom="10dp"
              app:cardElevation="2dp"
              app:cardCornerRadius="14dp"
              app:cardBackgroundColor="#FFF3E0"
              app:strokeColor="@color/amber"
              app:strokeWidth="1dp"
              android:visibility="gone"
              android:clickable="true"
              android:focusable="true">

              <LinearLayout
                  android:layout_width="match_parent"
                  android:layout_height="60dp"
                  android:orientation="horizontal"
                  android:gravity="center_vertical"
                  android:paddingHorizontal="18dp">

                  <ImageView
                      android:layout_width="26dp"
                      android:layout_height="26dp"
                      android:src="@drawable/ic_search"
                      app:tint="@color/amber"
                      android:layout_marginEnd="14dp"
                      android:contentDescription="Admin panel" />

                  <TextView
                      android:layout_width="0dp"
                      android:layout_height="wrap_content"
                      android:layout_weight="1"
                      android:text="অ্যাডমিন প্যানেল"
                      android:textSize="14sp"
                      android:textStyle="bold"
                      android:textColor="#7B5800" />

                  <com.google.android.material.switchmaterial.SwitchMaterial
                      android:id="@+id/sw_admin"
                      android:layout_width="wrap_content"
                      android:layout_height="wrap_content"
                      android:checked="false"
                      android:thumbTint="@color/amber"
                      android:trackTint="#FFCC80" />

              </LinearLayout>
          </com.google.android.material.card.MaterialCardView>

          <!-- ══ Continue Watching ══ -->
          <LinearLayout
              android:id="@+id/layout_continue_watching"
              android:layout_width="match_parent"
              android:layout_height="wrap_content"
              android:orientation="vertical"
              android:layout_marginBottom="8dp"
              android:visibility="gone">

              <TextView
                  android:layout_width="wrap_content"
                  android:layout_height="wrap_content"
                  android:text="দেখা চালিয়ে যান"
                  android:textSize="13sp"
                  android:textStyle="bold"
                  android:textColor="@color/t2"
                  android:paddingHorizontal="16dp"
                  android:paddingBottom="6dp" />

              <androidx.recyclerview.widget.RecyclerView
                  android:id="@+id/rv_continue_watching"
                  android:layout_width="match_parent"
                  android:layout_height="wrap_content"
                  android:orientation="horizontal"
                  app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                  android:paddingHorizontal="12dp"
                  android:paddingBottom="12dp"
                  android:clipToPadding="false" />
          </LinearLayout>

          <!-- ══ Section: অ্যাকাউন্ট ══ -->
          <TextView
              android:layout_width="wrap_content"
              android:layout_height="wrap_content"
              android:text="অ্যাকাউন্ট"
              android:textSize="12sp"
              android:textStyle="bold"
              android:textColor="@color/t3"
              android:paddingHorizontal="16dp"
              android:paddingBottom="6dp" />

          <com.google.android.material.card.MaterialCardView
              android:layout_width="match_parent"
              android:layout_height="wrap_content"
              android:layout_marginHorizontal="14dp"
              android:layout_marginBottom="14dp"
              app:cardElevation="1dp"
              app:cardCornerRadius="14dp"
              app:cardBackgroundColor="@color/surface">

              <LinearLayout
                  android:layout_width="match_parent"
                  android:layout_height="wrap_content"
                  android:orientation="vertical">

                  <!-- Storage info -->
                  <LinearLayout
                      android:layout_width="match_parent"
                      android:layout_height="54dp"
                      android:orientation="horizontal"
                      android:gravity="center_vertical"
                      android:paddingHorizontal="16dp">
                      <ImageView
                          android:layout_width="22dp"
                          android:layout_height="22dp"
                          android:src="@drawable/ic_download"
                          app:tint="@color/red"
                          android:layout_marginEnd="14dp"
                          android:contentDescription="Storage" />
                      <LinearLayout
                          android:layout_width="0dp"
                          android:layout_height="wrap_content"
                          android:layout_weight="1"
                          android:orientation="vertical">
                          <TextView
                              android:layout_width="wrap_content"
                              android:layout_height="wrap_content"
                              android:text="ডাউনলোড স্টোরেজ"
                              android:textSize="14sp"
                              android:textColor="@color/t1" />
                          <TextView
                              android:id="@+id/tv_storage"
                              android:layout_width="wrap_content"
                              android:layout_height="wrap_content"
                              android:text="গণনা হচ্ছে..."
                              android:textSize="12sp"
                              android:textColor="@color/t3" />
                      </LinearLayout>
                  </LinearLayout>

                  <View android:layout_width="match_parent" android:layout_height="1dp"
                      android:background="@color/border" android:layout_marginHorizontal="16dp"/>

                  <!-- Clear cache -->
                  <LinearLayout
                      android:id="@+id/btn_clear_cache"
                      android:layout_width="match_parent"
                      android:layout_height="54dp"
                      android:orientation="horizontal"
                      android:gravity="center_vertical"
                      android:paddingHorizontal="16dp"
                      android:background="?attr/selectableItemBackground"
                      android:clickable="true"
                      android:focusable="true"
                      android:contentDescription="Clear cache">
                      <ImageView
                          android:layout_width="22dp"
                          android:layout_height="22dp"
                          android:src="@drawable/ic_delete"
                          app:tint="@color/t2"
                          android:layout_marginEnd="14dp"
                          android:contentDescription="Delete" />
                      <TextView
                          android:layout_width="0dp"
                          android:layout_height="wrap_content"
                          android:layout_weight="1"
                          android:text="ক্যাশ মুছুন"
                          android:textSize="14sp"
                          android:textColor="@color/t1" />
                      <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                          android:text="›" android:textSize="18sp" android:textColor="@color/t3" />
                  </LinearLayout>

                  <View android:layout_width="match_parent" android:layout_height="1dp"
                      android:background="@color/border" android:layout_marginHorizontal="16dp"/>

                  <!-- Sign out -->
                  <LinearLayout
                      android:id="@+id/btn_sign_out"
                      android:layout_width="match_parent"
                      android:layout_height="54dp"
                      android:orientation="horizontal"
                      android:gravity="center_vertical"
                      android:paddingHorizontal="16dp"
                      android:background="?attr/selectableItemBackground"
                      android:clickable="true"
                      android:focusable="true"
                      android:contentDescription="Sign out">
                      <ImageView
                          android:layout_width="22dp"
                          android:layout_height="22dp"
                          android:src="@drawable/ic_close"
                          app:tint="@color/red"
                          android:layout_marginEnd="14dp"
                          android:contentDescription="Sign out icon" />
                      <TextView
                          android:layout_width="0dp"
                          android:layout_height="wrap_content"
                          android:layout_weight="1"
                          android:text="লগআউট"
                          android:textSize="14sp"
                          android:textColor="@color/red"
                          android:textStyle="bold" />
                  </LinearLayout>

              </LinearLayout>
          </com.google.android.material.card.MaterialCardView>

          <!-- ══ Section: সাপোর্ট ══ -->
          <TextView
              android:layout_width="wrap_content"
              android:layout_height="wrap_content"
              android:text="সাপোর্ট ও তথ্য"
              android:textSize="12sp"
              android:textStyle="bold"
              android:textColor="@color/t3"
              android:paddingHorizontal="16dp"
              android:paddingBottom="6dp" />

          <com.google.android.material.card.MaterialCardView
              android:layout_width="match_parent"
              android:layout_height="wrap_content"
              android:layout_marginHorizontal="14dp"
              android:layout_marginBottom="14dp"
              app:cardElevation="1dp"
              app:cardCornerRadius="14dp"
              app:cardBackgroundColor="@color/surface">

              <LinearLayout
                  android:layout_width="match_parent"
                  android:layout_height="wrap_content"
                  android:orientation="vertical">

                  <LinearLayout
                      android:id="@+id/btn_share_app"
                      android:layout_width="match_parent"
                      android:layout_height="54dp"
                      android:orientation="horizontal"
                      android:gravity="center_vertical"
                      android:paddingHorizontal="16dp"
                      android:background="?attr/selectableItemBackground"
                      android:clickable="true"
                      android:focusable="true"
                      android:contentDescription="Share app">
                      <ImageView android:layout_width="22dp" android:layout_height="22dp"
                          android:src="@drawable/ic_nav_profile" app:tint="@color/t2"
                          android:layout_marginEnd="14dp" android:contentDescription="Share" />
                      <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                          android:layout_weight="1" android:text="অ্যাপ শেয়ার করুন"
                          android:textSize="14sp" android:textColor="@color/t1" />
                      <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                          android:text="›" android:textSize="18sp" android:textColor="@color/t3" />
                  </LinearLayout>

                  <View android:layout_width="match_parent" android:layout_height="1dp"
                      android:background="@color/border" android:layout_marginHorizontal="16dp"/>

                  <LinearLayout
                      android:id="@+id/btn_contact_support"
                      android:layout_width="match_parent"
                      android:layout_height="54dp"
                      android:orientation="horizontal"
                      android:gravity="center_vertical"
                      android:paddingHorizontal="16dp"
                      android:background="?attr/selectableItemBackground"
                      android:clickable="true"
                      android:focusable="true"
                      android:contentDescription="Contact support">
                      <ImageView android:layout_width="22dp" android:layout_height="22dp"
                          android:src="@drawable/ic_nav_profile" app:tint="@color/t2"
                          android:layout_marginEnd="14dp" android:contentDescription="Contact" />
                      <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                          android:layout_weight="1" android:text="সাপোর্টে যোগাযোগ"
                          android:textSize="14sp" android:textColor="@color/t1" />
                      <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                          android:text="›" android:textSize="18sp" android:textColor="@color/t3" />
                  </LinearLayout>

                  <View android:layout_width="match_parent" android:layout_height="1dp"
                      android:background="@color/border" android:layout_marginHorizontal="16dp"/>

                  <LinearLayout
                      android:id="@+id/btn_privacy_policy"
                      android:layout_width="match_parent"
                      android:layout_height="54dp"
                      android:orientation="horizontal"
                      android:gravity="center_vertical"
                      android:paddingHorizontal="16dp"
                      android:background="?attr/selectableItemBackground"
                      android:clickable="true"
                      android:focusable="true"
                      android:contentDescription="Privacy policy">
                      <ImageView android:layout_width="22dp" android:layout_height="22dp"
                          android:src="@drawable/ic_lock" app:tint="@color/t2"
                          android:layout_marginEnd="14dp" android:contentDescription="Privacy" />
                      <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                          android:layout_weight="1" android:text="প্রাইভেসি পলিসি"
                          android:textSize="14sp" android:textColor="@color/t1" />
                      <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                          android:text="›" android:textSize="18sp" android:textColor="@color/t3" />
                  </LinearLayout>

                  <View android:layout_width="match_parent" android:layout_height="1dp"
                      android:background="@color/border" android:layout_marginHorizontal="16dp"/>

                  <LinearLayout
                      android:id="@+id/btn_about"
                      android:layout_width="match_parent"
                      android:layout_height="54dp"
                      android:orientation="horizontal"
                      android:gravity="center_vertical"
                      android:paddingHorizontal="16dp"
                      android:background="?attr/selectableItemBackground"
                      android:clickable="true"
                      android:focusable="true"
                      android:contentDescription="About app">
                      <ImageView android:layout_width="22dp" android:layout_height="22dp"
                          android:src="@drawable/ic_search" app:tint="@color/t2"
                          android:layout_marginEnd="14dp" android:contentDescription="About" />
                      <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                          android:layout_weight="1" android:text="অ্যাপ সম্পর্কে"
                          android:textSize="14sp" android:textColor="@color/t1" />
                      <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                          android:text="›" android:textSize="18sp" android:textColor="@color/t3" />
                  </LinearLayout>

              </LinearLayout>
          </com.google.android.material.card.MaterialCardView>

          <!-- Version tag -->
          <TextView
              android:layout_width="match_parent"
              android:layout_height="wrap_content"
              android:text="CineStream v2.9.0 · MoviePlexBD"
              android:textSize="12sp"
              android:textColor="@color/t3"
              android:gravity="center"
              android:paddingVertical="8dp" />

      </LinearLayout>
  </ScrollView>