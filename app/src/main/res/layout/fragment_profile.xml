<?xml version="1.0" encoding="utf-8"?>
  <ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
      xmlns:app="http://schemas.android.com/apk/res-auto"
      android:layout_width="match_parent"
      android:layout_height="match_parent"
      android:background="@color/bg"
      android:scrollbars="none"
      android:overScrollMode="never">

      <LinearLayout
          android:layout_width="match_parent"
          android:layout_height="wrap_content"
          android:orientation="vertical"
          android:paddingBottom="24dp">

          <!-- Profile Card -->
          <androidx.cardview.widget.CardView
              android:layout_width="match_parent"
              android:layout_height="wrap_content"
              android:layout_margin="14dp"
              app:cardCornerRadius="18dp"
              app:cardElevation="2dp"
              app:cardBackgroundColor="@color/surface">

              <LinearLayout
                  android:layout_width="match_parent"
                  android:layout_height="wrap_content"
                  android:orientation="vertical"
                  android:gravity="center"
                  android:padding="24dp">

                  <de.hdodenhof.circleimageview.CircleImageView
                      android:id="@+id/iv_avatar"
                      android:layout_width="80dp"
                      android:layout_height="80dp"
                      android:src="@color/red"
                      app:civ_border_width="2dp"
                      app:civ_border_color="@color/border" />

                  <TextView
                      android:id="@+id/tv_name"
                      android:layout_width="wrap_content"
                      android:layout_height="wrap_content"
                      android:text="ব্যবহারকারী"
                      android:textSize="20sp"
                      android:textStyle="bold"
                      android:textColor="@color/t1"
                      android:fontFamily="serif"
                      android:layout_marginTop="12dp" />

                  <TextView
                      android:id="@+id/tv_email"
                      android:layout_width="wrap_content"
                      android:layout_height="wrap_content"
                      android:textSize="13sp"
                      android:textColor="@color/t2"
                      android:layout_marginTop="4dp" />

                  <TextView
                      android:id="@+id/tv_plan_label"
                      android:layout_width="wrap_content"
                      android:layout_height="wrap_content"
                      android:paddingHorizontal="16dp"
                      android:paddingVertical="5dp"
                      android:textSize="12sp"
                      android:textStyle="bold"
                      android:textColor="@color/white"
                      android:layout_marginTop="12dp" />

                  <TextView
                      android:id="@+id/tv_expiry"
                      android:layout_width="wrap_content"
                      android:layout_height="wrap_content"
                      android:textSize="12sp"
                      android:textColor="@color/t3"
                      android:layout_marginTop="4dp"
                      android:visibility="gone" />
              </LinearLayout>
          </androidx.cardview.widget.CardView>

          <!-- Admin Panel Button (hidden by default, visible only for admin) -->
          <com.google.android.material.button.MaterialButton
              android:id="@+id/btn_admin"
              android:layout_width="match_parent"
              android:layout_height="52dp"
              android:layout_marginHorizontal="14dp"
              android:layout_marginBottom="10dp"
              android:text="⚙ অ্যাডমিন প্যানেল"
              android:textSize="15sp"
              android:textColor="@color/white"
              android:backgroundTint="@color/t1"
              app:cornerRadius="13dp"
              android:visibility="gone" />

          <!-- Storage Info -->
          <androidx.cardview.widget.CardView
              android:layout_width="match_parent"
              android:layout_height="wrap_content"
              android:layout_marginHorizontal="14dp"
              android:layout_marginBottom="10dp"
              app:cardCornerRadius="13dp"
              app:cardElevation="1dp"
              app:cardBackgroundColor="@color/surface">

              <LinearLayout
                  android:layout_width="match_parent"
                  android:layout_height="wrap_content"
                  android:orientation="horizontal"
                  android:gravity="center_vertical"
                  android:padding="16dp">

                  <TextView
                      android:layout_width="wrap_content"
                      android:layout_height="wrap_content"
                      android:text="📦"
                      android:textSize="20sp"
                      android:layout_marginEnd="12dp" />

                  <TextView
                      android:id="@+id/tv_storage"
                      android:layout_width="wrap_content"
                      android:layout_height="wrap_content"
                      android:text="ডাউনলোড স্টোরেজ: ..."
                      android:textSize="14sp"
                      android:textColor="@color/t2" />
              </LinearLayout>
          </androidx.cardview.widget.CardView>

          <!-- Premium info card -->
          <androidx.cardview.widget.CardView
              android:layout_width="match_parent"
              android:layout_height="wrap_content"
              android:layout_marginHorizontal="14dp"
              android:layout_marginBottom="24dp"
              app:cardCornerRadius="13dp"
              app:cardElevation="1dp"
              app:cardBackgroundColor="@color/red_soft">

              <LinearLayout
                  android:layout_width="match_parent"
                  android:layout_height="wrap_content"
                  android:orientation="vertical"
                  android:padding="16dp">

                  <TextView
                      android:layout_width="wrap_content"
                      android:layout_height="wrap_content"
                      android:text="প্রিমিয়াম সাবস্ক্রিপশন"
                      android:textSize="14sp"
                      android:textStyle="bold"
                      android:textColor="@color/red" />

                  <TextView
                      android:layout_width="wrap_content"
                      android:layout_height="wrap_content"
                      android:text="সাবস্ক্রিপশন পরিবর্তন বা আপগ্রেডের জন্য অ্যাডমিনের সাথে যোগাযোগ করুন।"
                      android:textSize="12sp"
                      android:textColor="@color/t2"
                      android:layout_marginTop="4dp"
                      android:lineSpacingMultiplier="1.5" />
              </LinearLayout>
          </androidx.cardview.widget.CardView>

          <!-- Sign Out Button -->
          <com.google.android.material.button.MaterialButton
              android:id="@+id/btn_sign_out"
              android:layout_width="match_parent"
              android:layout_height="52dp"
              android:layout_marginHorizontal="14dp"
              android:text="@string/btn_signout"
              android:textSize="15sp"
              android:textColor="@color/red"
              style="@style/Widget.MaterialComponents.Button.OutlinedButton"
              app:strokeColor="@color/red"
              app:strokeWidth="1.5dp"
              app:cornerRadius="13dp"
              android:backgroundTint="@color/transparent" />

      </LinearLayout>
  </ScrollView>
  