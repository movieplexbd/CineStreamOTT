<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg"
    android:scrollbars="none"
    android:overScrollMode="never">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="24dp">

        <!-- ══ Hero Profile Card (Refined & Smaller) ══ -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="12dp"
            app:cardElevation="2dp"
            app:cardCornerRadius="24dp"
            app:cardBackgroundColor="@color/surface"
            app:strokeWidth="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="20dp">

                <!-- Avatar with ring -->
                <FrameLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content">

                    <de.hdodenhof.circleimageview.CircleImageView
                        android:id="@+id/iv_avatar"
                        android:layout_width="72dp"
                        android:layout_height="72dp"
                        android:src="@drawable/ic_profile"
                        app:civ_border_width="2dp"
                        app:civ_border_color="@color/red"
                        android:contentDescription="Profile photo" />

                </FrameLayout>

                <TextView
                    android:id="@+id/tv_name"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="ব্যবহারকারী"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="@color/t1"
                    android:layout_marginTop="12dp" />

                <TextView
                    android:id="@+id/tv_email"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="12sp"
                    android:textColor="@color/t2"
                    android:layout_marginTop="2dp" />

                <!-- Subscription badge -->
                <TextView
                    android:id="@+id/tv_plan_label"
                    android:layout_width="wrap_content"
                    android:layout_height="28dp"
                    android:paddingHorizontal="14dp"
                    android:gravity="center"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:textColor="@color/white"
                    android:background="@drawable/bg_free_badge"
                    android:layout_marginTop="10dp"
                    android:text="ফ্রি প্ল্যান" />

                <TextView
                    android:id="@+id/tv_expiry"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="11sp"
                    android:textColor="@color/t3"
                    android:layout_marginTop="4dp"
                    android:visibility="gone" />

                <!-- Action Buttons Row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="16dp"
                    android:gap="10dp">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_subscribe"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="44dp"
                        android:text="আপগ্রেড ✨"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:textColor="@color/white"
                        app:cornerRadius="12dp"
                        app:backgroundTint="@color/red"
                        android:layout_marginEnd="5dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_watchlist"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="44dp"
                        android:text="ওয়াচলিস্ট"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:textColor="@color/red"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                        app:strokeColor="@color/red"
                        app:strokeWidth="1dp"
                        app:cornerRadius="12dp"
                        app:backgroundTint="@color/transparent"
                        android:layout_marginStart="5dp" />

                </LinearLayout>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ══ Admin Control Card (hidden for non-admins) ══ -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/btn_admin"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginBottom="10dp"
            app:cardElevation="1dp"
            app:cardCornerRadius="14dp"
            app:cardBackgroundColor="#FFF3E0"
            app:strokeColor="@color/amber"
            app:strokeWidth="1dp"
            android:visibility="gone"
            android:clickable="true"
            android:focusable="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingHorizontal="16dp">

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_search"
                    app:tint="@color/amber"
                    android:layout_marginEnd="12dp"
                    android:contentDescription="Admin panel" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="অ্যাডমিন প্যানেল"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="#7B5800" />

                <com.google.android.material.switchmaterial.SwitchMaterial
                    android:id="@+id/sw_admin"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:checked="false"
                    android:thumbTint="@color/amber"
                    android:trackTint="#FFCC80" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ══ Continue Watching ══ -->
        <LinearLayout
            android:id="@+id/layout_continue_watching"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="8dp"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="দেখা চালিয়ে যান"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="@color/t2"
                android:paddingHorizontal="16dp"
                android:paddingBottom="6dp" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_continue_watching"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                android:paddingHorizontal="12dp"
                android:paddingBottom="12dp"
                android:clipToPadding="false" />
        </LinearLayout>

        <!-- ══ Section: অ্যাকাউন্ট ══ -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="অ্যাকাউন্ট"
            android:textSize="12sp"
            android:textStyle="bold"
            android:textColor="@color/t3"
            android:paddingHorizontal="16dp"
            android:paddingBottom="6dp" />

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginBottom="14dp"
            app:cardElevation="1dp"
            app:cardCornerRadius="14dp"
            app:cardBackgroundColor="@color/surface">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- Storage info -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="54dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="16dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:background="?attr/selectableItemBackground">
                    <ImageView
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:src="@drawable/ic_download"
                        app:tint="@color/red"
                        android:layout_marginEnd="16dp" />
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="ডাউনলোড স্টোরেজ"
                        android:textSize="14sp"
                        android:textColor="@color/t1" />
                    <TextView
                        android:id="@+id/tv_storage"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0 MB"
                        android:textSize="13sp"
                        android:textColor="@color/t3" />
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/bg" android:layout_marginHorizontal="16dp" />

                <!-- Clear Cache -->
                <LinearLayout
                    android:id="@+id/btn_clear_cache"
                    android:layout_width="match_parent"
                    android:layout_height="54dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="16dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:background="?attr/selectableItemBackground">
                    <ImageView
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:src="@drawable/ic_search"
                        app:tint="@color/red"
                        android:layout_marginEnd="16dp" />
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="ক্যাশ পরিষ্কার করুন"
                        android:textSize="14sp"
                        android:textColor="@color/t1" />
                </LinearLayout>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ══ Section: সাপোর্ট ও অন্যান্য ══ -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="সাপোর্ট ও অন্যান্য"
            android:textSize="12sp"
            android:textStyle="bold"
            android:textColor="@color/t3"
            android:paddingHorizontal="16dp"
            android:paddingBottom="6dp" />

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginBottom="14dp"
            app:cardElevation="1dp"
            app:cardCornerRadius="14dp"
            app:cardBackgroundColor="@color/surface">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- Share App -->
                <LinearLayout
                    android:id="@+id/btn_share_app"
                    android:layout_width="match_parent"
                    android:layout_height="54dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="16dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:background="?attr/selectableItemBackground">
                    <ImageView
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:src="@drawable/ic_share"
                        app:tint="@color/red"
                        android:layout_marginEnd="16dp" />
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="অ্যাপ শেয়ার করুন"
                        android:textSize="14sp"
                        android:textColor="@color/t1" />
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/bg" android:layout_marginHorizontal="16dp" />

                <!-- Contact Support -->
                <LinearLayout
                    android:id="@+id/btn_contact_support"
                    android:layout_width="match_parent"
                    android:layout_height="54dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="16dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:background="?attr/selectableItemBackground">
                    <ImageView
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:src="@drawable/ic_email"
                        app:tint="@color/red"
                        android:layout_marginEnd="16dp" />
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="যোগাযোগ করুন"
                        android:textSize="14sp"
                        android:textColor="@color/t1" />
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/bg" android:layout_marginHorizontal="16dp" />

                <!-- Privacy Policy -->
                <LinearLayout
                    android:id="@+id/btn_privacy_policy"
                    android:layout_width="match_parent"
                    android:layout_height="54dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="16dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:background="?attr/selectableItemBackground">
                    <ImageView
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:src="@drawable/ic_privacy"
                        app:tint="@color/red"
                        android:layout_marginEnd="16dp" />
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="প্রাইভেসি পলিসি"
                        android:textSize="14sp"
                        android:textColor="@color/t1" />
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/bg" android:layout_marginHorizontal="16dp" />

                <!-- About -->
                <LinearLayout
                    android:id="@+id/btn_about"
                    android:layout_width="match_parent"
                    android:layout_height="54dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="16dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:background="?attr/selectableItemBackground">
                    <ImageView
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:src="@drawable/ic_info"
                        app:tint="@color/red"
                        android:layout_marginEnd="16dp" />
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="অ্যাপ সম্পর্কে"
                        android:textSize="14sp"
                        android:textColor="@color/t1" />
                </LinearLayout>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ══ Sign Out ══ -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_sign_out"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="8dp"
            android:text="লগআউট করুন"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="@color/red"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            app:icon="@drawable/ic_logout"
            app:iconTint="@color/red"
            app:iconGravity="textStart"
            app:iconPadding="12dp" />

    </LinearLayout>
</ScrollView>
