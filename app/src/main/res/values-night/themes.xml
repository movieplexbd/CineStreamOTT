<?xml version="1.0" encoding="utf-8"?>
  <resources>

      <!-- ═══ Deep Dark Theme (#0A0A0A) — OTT Night Mode ═══ -->
      <style name="Theme.OTTStreamingApp" parent="Theme.Material3.Dark.NoActionBar">
          <item name="colorPrimary">@color/red</item>
          <item name="colorOnPrimary">@color/white</item>
          <item name="colorPrimaryContainer">#5C1A0A</item>
          <item name="colorOnPrimaryContainer">#FFD5C8</item>
          <item name="colorSecondary">@color/amber</item>
          <item name="colorOnSecondary">@color/black</item>
          <item name="colorTertiary">@color/blue</item>
          <item name="colorSurface">@color/surface</item>
          <item name="colorOnSurface">@color/t1</item>
          <item name="colorSurfaceVariant">@color/surface2</item>
          <item name="colorOnSurfaceVariant">@color/t2</item>
          <item name="colorOutline">@color/border</item>
          <item name="android:colorBackground">@color/bg</item>
          <item name="android:windowBackground">@color/bg</item>
          <item name="android:statusBarColor">@android:color/transparent</item>
          <item name="android:navigationBarColor">@color/surface</item>
          <item name="android:windowLightStatusBar">false</item>
          <item name="android:windowActivityTransitions">true</item>
          <item name="windowActionBar">false</item>
          <item name="windowNoTitle">true</item>
      </style>

      <style name="Theme.OTTStreamingApp.NoActionBar" parent="Theme.OTTStreamingApp" />

      <style name="Theme.OTTStreamingApp.Login" parent="Theme.OTTStreamingApp">
          <item name="android:windowSoftInputMode">adjustResize</item>
      </style>

  </resources>